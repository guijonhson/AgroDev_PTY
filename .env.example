# Configuración de AgroDev para Producción
# Copiar este archivo como .env y completar los valores

# SECRET_KEY: Generar con: python -c "import secrets; print(secrets.token_hex(24))"
SECRET_KEY=tu-secret-key-aqui

# FLASK_ENV: development, production, o testing
FLASK_ENV=development

# FLASK_DEBUG: True o False
FLASK_DEBUG=True

# DATABASE_URL (opcional - si no se establece, usa SQLite por defecto)
# DATABASE_URL=sqlite:////ruta/absoluta/a/database/agrodev.db
# Para producción con PostgreSQL: postgresql://user:password@localhost/agrodev