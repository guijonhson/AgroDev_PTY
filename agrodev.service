[Unit]
Description=AgroDev Gunicorn
After=network.target

[Service]
User=root
WorkingDirectory=/root/AgroDev_PTY
Environment="PATH=/root/AgroDev_PTY/venv/bin"
Environment="FLASK_ENV=production"
ExecStart=/root/AgroDev_PTY/venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 run:app

[Install]
WantedBy=multi-user.target